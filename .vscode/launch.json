{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: api",
      "program": "${workspaceFolder}/api/Edimus.Api/bin/Debug/net8.0/Edimus.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/api/Edimus.Api",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7183;http://localhost:5183"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}"
      }
    },
    {
      "name": "Attach to API",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
