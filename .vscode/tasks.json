{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/api/Edimus.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "publish: api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/api/Edimus.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch: api",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/api/Edimus.Api/Edimus.Api.csproj"
      ],
      "problemMatcher": "$msCompile",
      "isBackground": true
    },
    {
      "label": "migrations: add",
      "command": "dotnet",
      "type": "process",
      "args": [
        "ef",
        "migrations",
        "add",
        "${input:migrationName}",
        "--project",
        "${workspaceFolder}/api/Common/Shared.Infrastructure",
        "--startup-project",
        "${workspaceFolder}/api/Edimus.Api"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "migrations: remove last",
      "command": "dotnet",
      "type": "process",
      "args": [
        "ef",
        "migrations",
        "remove",
        "--project",
        "${workspaceFolder}/api/Common/Shared.Infrastructure",
        "--startup-project",
        "${workspaceFolder}/api/Edimus.Api"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "migrations: run",
      "type": "shell",
      "command": "dotnet ef database update ${input:targetMigration} --project '${workspaceFolder}/api/Common/Shared.Infrastructure' --startup-project '${workspaceFolder}/api/Edimus.Api'",
      "problemMatcher": "$msCompile"
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Migration name"
    },
    {
      "id": "targetMigration",
      "type": "promptString",
      "description": "Target migration (leave blank to apply all pending)"
    }
  ]
}
