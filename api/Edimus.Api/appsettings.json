{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/edimus-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "JWT": {
    "Secret": "",
    "Expiration": 30,
    "RefreshExpiration": 7,
    "Issuer": "Edimus.Api",
    "Audience": "Edimus.Client"
  },
  "Email": {
    "OriginEmail": "",
    "OriginPassword": "",
    "FrontendUrl": "http://localhost:3000"
  }
}
